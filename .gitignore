# OS artifacts
.DS_Store
**/.DS_Store

# Secrets and local environment files
.env
.env.*
!.env.example
.envrc
*.pem
*.key
*.p12
*.pfx

# Editor and workspace settings
.vscode/
.idea/
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp
*.temp
*.pid
*.bak
*.orig
.remember/

# Ephemeral pipeline-mode scratch space (see docs/minion-prompt-modes.md)
.pipeline/

# xtool delegate worktree scratch space (never merged, human gate applies)
.xtool-worktrees/

# Claude Code native worktree directory (managed by Claude Code, not for commit)
.claude/worktrees/

# Python artifacts (if minions/scripts are added)
__pycache__/
*.py[cod]
.venv/
venv/

# Node artifacts (if helper tooling is added)
node_modules/
dist/
coverage/

# Superpowers SDD scratch (briefs, reports, diffs, progress ledger)
.superpowers/
